# App Store Connect API key, sourced from 1Password at runtime.
# These are op:// *references* — not secrets. Resolved only inside `op run`:
#   op run --env-file=.env.asc -- fastlane release
ASC_KEY_ID=op://Private/fastlane-scan-screen-qr-code/key_id
ASC_ISSUER_ID=op://Private/fastlane-scan-screen-qr-code/issuer_id
ASC_KEY_CONTENT=op://Private/fastlane-scan-screen-qr-code/key_content

# App Review contact info — only the phone is private. Name/email are
# already in Appfile and the copyright; no need to vault them too.
ASC_REVIEW_PHONE=op://Private/fastlane-scan-screen-qr-code/review_phone
