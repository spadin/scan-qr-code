# Mac App Store release pipeline for Scan QR Code.
#
# This is a SwiftPM app (no .xcodeproj), so the build itself is done by
# scripts/build-app.sh + scripts/package-mas.sh; fastlane handles the parts it
# does best: signing assets and uploading to App Store Connect.
#
# Prerequisites (one-time, see README "Mac App Store submission"):
#   1. Apple Developer Program membership.
#   2. App record + bundle ID `com.sandropadin.ScanQRCode` in App Store Connect.
#   3. An App Store Connect API key (.p8). Supply it one of two ways:
#      a. via 1Password — no secrets on disk. Run lanes under `op run`:
#           op run --env-file=.env.asc -- fastlane release
#         `key_content` holds the .p8 contents, base64-encoded.
#      b. as a file on disk:
#           export ASC_KEY_ID=XXXXXXXXXX
#           export ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#           export ASC_KEY_PATH="$HOME/.appstoreconnect/AuthKey_XXXXXXXXXX.p8"
#
# Usage:  fastlane certs   |   fastlane package   |   fastlane upload
#         fastlane release   (certs → package → upload)

require "shellwords"

default_platform(:mac)

def asc_api_key
  return nil unless ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"]

  if ENV["ASC_KEY_CONTENT"]
    # Preferred: key supplied in-process (e.g. via `op run`) — never on disk.
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )
  elsif ENV["ASC_KEY_PATH"]
    # Fallback: .p8 file on disk.
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
  end
end

# Locate the Mac App Store provisioning profile `fastlane certs` (sigh)
# downloaded: an explicit PROVISIONING_PROFILE wins, then the in-process sigh
# result, then the newest *.provisionprofile in the repo root.
def provisioning_profile_path
  explicit = ENV["PROVISIONING_PROFILE"]
  return explicit if explicit && File.exist?(explicit)

  ctx = Actions.lane_context[Actions::SharedValues::SIGH_PROFILE_PATH]
  return ctx if ctx && File.exist?(ctx)

  root = File.expand_path("..", __dir__)
  Dir["#{root}/*.provisionprofile"].max_by { |f| File.mtime(f) }
end

platform :mac do
  desc "One-time: register the bundle ID + create the App Store Connect app record"
  lane :setup do
    # Replaces the manual Developer-portal + App Store Connect clicking:
    # `produce` registers the App ID and creates the macOS app record.
    produce(
      app_name: "Scan Screen QR Code",
      app_identifier: "com.sandropadin.ScanQRCode",
      platforms: ["osx"],
      api_key: asc_api_key
    )
    certs
    UI.success("App record + bundle ID + signing assets ready.")
  end

  desc "Create/fetch the Apple Distribution cert and Mac App Store profile"
  lane :certs do
    key = asc_api_key
    # Apple Distribution signing certificate (for the .app).
    cert(platform: "macos", api_key: key)
    # Mac App Store provisioning profile for the bundle ID.
    sigh(
      platform: "macos",
      app_identifier: "com.sandropadin.ScanQRCode",
      api_key: key
    )
    UI.message("Distribution cert + profile ready.")
    UI.important("The 'Mac Installer Distribution' certificate must be " \
      "created once in the Developer portal (or Xcode ▸ Settings ▸ Accounts " \
      "▸ Manage Certificates) — fastlane cannot mint installer certs.")
  end

  desc "Build + sign the .app and produce a signed .pkg for the App Store"
  lane :package do
    profile = provisioning_profile_path
    unless profile && File.exist?(profile)
      UI.user_error!("No .provisionprofile found — run `fastlane certs` first " \
        "(or set PROVISIONING_PROFILE).")
    end
    UI.message("Using provisioning profile: #{profile}")
    sh("cd .. && PROVISIONING_PROFILE=#{profile.shellescape} ./scripts/package-mas.sh")
  end

  desc "Upload the signed .pkg to App Store Connect"
  lane :upload do
    pkg = File.expand_path("../build/ScanQRCode.pkg", __dir__)
    UI.user_error!("No package at #{pkg} — run `fastlane package` first.") unless File.exist?(pkg)
    upload_to_app_store(
      pkg: pkg,
      api_key: asc_api_key,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      submit_for_review: false
    )
  end

  desc "Validate the signed .pkg against App Store Connect (no upload)"
  lane :verify do
    pkg = File.expand_path("../build/ScanQRCode.pkg", __dir__)
    UI.user_error!("No package at #{pkg} — run `fastlane package` first.") unless File.exist?(pkg)
    upload_to_app_store(
      pkg: pkg,
      api_key: asc_api_key,
      skip_metadata: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      verify_only: true
    )
  end

  desc "Deep server-side diagnostic: app versions, prerelease versions, builds"
  lane :diagnose do
    require "spaceship"
    require "base64"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key: Base64.decode64(ENV["ASC_KEY_CONTENT"].to_s)
    )
    app = Spaceship::ConnectAPI::App.find("com.sandropadin.ScanQRCode")
    UI.user_error!("No app record found") unless app
    UI.success("App: #{app.name} (id #{app.id}) bundle=#{app.bundle_id}")

    UI.header("App Store versions")
    begin
      versions = app.get_app_store_versions
      if versions.to_a.empty?
        UI.important("  none")
      else
        versions.each do |v|
          UI.message("  #{v.version_string}  platform=#{v.platform}  state=#{v.app_store_state}")
        end
      end
    rescue => e
      UI.error("  failed: #{e.message}")
    end

    UI.header("Prerelease (TestFlight) versions")
    begin
      pre = Spaceship::ConnectAPI.get_prerelease_versions(filter: { app: app.id })
      if pre.to_a.empty?
        UI.important("  none")
      else
        pre.each { |p| UI.message("  #{p.version}  platform=#{p.platform}") }
      end
    rescue => e
      UI.error("  failed: #{e.message}")
    end

    UI.header("Builds (all platforms, newest first)")
    begin
      builds = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 20)
      if builds.to_a.empty?
        UI.important("  none")
      else
        builds.each do |b|
          UI.message("  build #{b.version}  state=#{b.processing_state}  expired=#{b.expired}  uploaded=#{b.uploaded_date}")
        end
      end
    rescue => e
      UI.error("  failed: #{e.message}")
    end
  end

  desc "Full release: certs → package → upload"
  lane :release do
    certs
    package
    upload
  end

  desc "Show recent builds + their App Store Connect processing state"
  lane :status do
    require "spaceship"
    require "base64"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key: Base64.decode64(ENV["ASC_KEY_CONTENT"].to_s)
    )
    app = Spaceship::ConnectAPI::App.find("com.sandropadin.ScanQRCode")
    UI.user_error!("No app record found for com.sandropadin.ScanQRCode") unless app
    UI.success("App: #{app.name} (id #{app.id})")
    builds = Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 10)
    if builds.to_a.empty?
      UI.important("No builds found — nothing has landed in App Store Connect yet.")
    else
      builds.each do |b|
        UI.message("build #{b.version}  state=#{b.processing_state}  uploaded=#{b.uploaded_date}")
      end
    end
  end
end
